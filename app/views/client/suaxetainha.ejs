<script>
function getLocation() {
  const output = document.getElementById("location-output");
  if (!navigator.geolocation) {
    output.innerHTML = "Trình duyệt không hỗ trợ định vị vị trí.";
    return;
  }
  output.innerHTML = "⏳ Đang lấy vị trí...";
  
  navigator.geolocation.getCurrentPosition((position) => {
    const lat = position.coords.latitude;
    const lon = position.coords.longitude;
    const googleMapsLink = `https://www.google.com/maps?q=${lat},${lon}`;
    output.innerHTML = `✅ Vị trí hiện tại: <a href="${googleMapsLink}" target="_blank">Xem trên Google Maps</a>`;
  }, () => {
    output.innerHTML = "❌ Không thể lấy vị trí. Vui lòng bật GPS và thử lại.";
  });
}
</script>

