<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QUÊN MẬT KHẨU - VQTBIKE</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <!-- CSS (Dùng chung với login) -->
    <link rel="stylesheet" href="css/login.css">
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Phần hình ảnh bên trái -->
            <div class="col-lg-7 d-none d-lg-block left-side">
                <div class="overlay"></div>
                <div class="left-content">
                    <div class="logo-container mb-5">
                        <img src="images/logo1.png" alt="Logo Sửa Xe Nhanh" class="logo">
                        <h2 class="brand-name">SỬA XE VQTBIKE</h2>
                    </div>
                    <h1 class="welcome-text">Dịch vụ sửa xe máy chuyên nghiệp</h1>
                    <p class="welcome-description">Đặt lịch sửa xe dễ dàng - Nhanh chóng - Tiện lợi</p>
                </div>
            </div>
            
            <!-- Phần form bên phải -->
            <div class="col-lg-5 right-side">
                <div class="login-container">
                    <div class="login-header">
                        <div class="d-lg-none text-center mb-4">
                            <img src="images/maintenance.png" alt="Logo Sửa Xe Nhanh" height="60">
                            <h2 class="mt-2 brand-name">SỬA XE VQTBIKE</h2>
                        </div>
                        <h3 class="login-title">Quên Mật Khẩu</h3>
                        <p class="login-subtitle">Nhập email của bạn để nhận mật khẩu mới</p>
                    </div>
                    
                    <!-- Thông báo -->
                    <div class="alert alert-danger" id="error-alert" style="display: none;"></div>
                    <div class="alert alert-success" id="success-alert" style="display: none;"></div>
                    
                    <!-- Form -->
                    <form id="forgotPasswordForm">
                        <div class="mb-4">
                            <label for="email" class="form-label">Email</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input type="email" class="form-control" id="email" placeholder="Nhập email của bạn" required>
                            </div>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100 login-btn" id="submitButton">
                            <span class="spinner-border spinner-border-sm me-2" id="submitSpinner" style="display: none;"></span>
                            Gửi mật khẩu mới
                        </button>
                        
                        <div class="register-link mt-4 text-center">
                            Đã nhớ lại mật khẩu? <a href="/login" class="text-decoration-none">Đăng nhập</a>
                        </div>

                        <div class="back-to-site mt-3 text-center">
                            <a href="/" class="text-decoration-none">
                                <i class="bi bi-arrow-left me-1"></i> Quay lại trang chủ
                            </a>
                        </div>
                        
                    </form>
                    <div class="login-footer">
                        <p>&copy; 2025 Sửa Xe Nhanh. All rights reserved.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Config & Custom JS -->
    <script src="js/config.js"></script>
    <script src="js/forgot-password.js"></script>
</body>
</html>
