<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chấm công - Admin Dashboard</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="css/admin.css">
    <link rel="stylesheet" href="css/notification-admin.css">
    <link rel="stylesheet" href="css/admin-attendance.css">
    
    <script src="js/common-header.js"></script>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar - GIỐNG Y ADMIN-MECHANICS -->
            <nav id="sidebar" class="col-md-3 col-lg-2 d-md-block bg-dark sidebar collapsed">
                <div class="position-sticky">
                    <div class="text-center py-4 mb-3">
                        <img src="images/maintenance.png" alt="Logo" width="50" height="50">
                        <h5 class="text-white mt-2">Trang Admin</h5>
                    </div>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link" href="/admin" id="dashboard-link">
                                <i class="bi bi-speedometer2 me-2"></i>
                                Tổng quan
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/admin-services" id="services-link">
                                <i class="bi bi-tools me-2"></i>
                                Quản lý Dịch vụ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/admin-booking" id="bookings-link">
                                <i class="bi bi-calendar-check me-2"></i>
                                Quản lý Đặt lịch
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/admin-users" id="users-link">
                                <i class="bi bi-people me-2"></i>
                                Quản lý Tài khoản
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/admin-mechanics" id="mechanics-link">
                                <i class="bi bi-person-badge me-2"></i>
                                Quản lý Kỹ thuật viên
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/admin-revenue" id="revenue-link">
                                <i class="bi bi-cash-stack me-2"></i>
                                Thống kê Doanh thu
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/admin-schedules" id="schedules-link">
                                <i class="bi bi-calendar-week me-2"></i>
                                Quản lý Lịch làm việc
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link active" href="/admin-attendance" id="attendance-link">
                                <i class="bi bi-clock-history me-2"></i>
                                Chấm công
                            </a>
                        </li>
                        <li class="nav-item mt-4">
                            <a class="nav-link text-danger" href="#" id="logout-link">
                                <i class="bi bi-box-arrow-right me-2"></i>
                                Đăng xuất
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Main Content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
                <!-- Header -->
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2">Chấm công</h1>
                    <div class="user-info d-flex align-items-center gap-3">
                        <span id="adminName">Admin</span>
                        
                        <div class="dropdown">
                            <a href="#" class="d-block link-dark text-decoration-none dropdown-toggle" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="avatar-placeholder" id="avatarPlaceholder"></div>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end text-small" aria-labelledby="dropdownUser">
                                <li><a class="dropdown-item" href="/">Trang chủ</a></li>
                                <li><a class="dropdown-item" href="/profile">Thông tin tài khoản</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/" id="dropdown-logout">Đăng xuất</a></li>
                            </ul>
                        </div>
                        
                        <!-- Notification Bell -->
                        <div class="notification-bell">
                            <button class="bell-button" id="notificationBell">
                                <svg class="bell-icon" viewBox="0 0 24 24">
                                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                                    <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                                </svg>
                                <span class="notification-badge" id="notificationBadge" style="display: none;">0</span>
                            </button>
                            
                            <div class="notification-dropdown" id="notificationDropdown">
                                <div class="dropdown-header">
                                    <h3>Thông báo</h3>
                                </div>
                                
                                <div class="notification-tabs">
                                    <button class="tab-button active" data-tab="all">Tất cả</button>
                                    <button class="tab-button" data-tab="unread">
                                        Chưa đọc <span class="tab-count" id="unreadTabCount"></span>
                                    </button>
                                </div>
                                
                                <div class="notifications-list" id="notificationsList">
                                    <div class="loading" id="loadingState">
                                        <div class="spinner"></div>
                                        <p>Đang tải...</p>
                                    </div>
                                    
                                    <div class="empty-state" id="emptyState" style="display: none;">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                                            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                                        </svg>
                                        <p>Không có thông báo</p>
                                    </div>
                                </div>
                                
                                <div class="dropdown-footer">
                                    <button class="mark-all-read" id="markAllRead">
                                        Đánh dấu tất cả đã đọc
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Attendance Content -->
                <div class="row mt-4">
                    <!-- QR CODE SECTION -->
                    <div class="col-md-4">
                        <div class="card shadow">
                            <div class="card-body text-center">
                                <h5 class="card-title">
                                    <i class="bi bi-qr-code-scan"></i> Mã QR Chấm Công
                                </h5>
                                <p class="text-muted">Tự động đổi mới 30 giây</p>
                                
                                <!-- QR Code Container -->
                                <div id="qrCodeContainer"></div>
                                
                                <!-- Countdown -->
                                <div class="countdown" id="countdown">30</div>
                                <div class="progress mb-3" style="height: 10px;">
                                    <div id="progressBar" class="progress-bar bg-success" style="width: 100%"></div>
                                </div>
                                
                                <small class="text-muted">Nhân viên quét mã QR này để chấm công</small>
                            </div>
                        </div>
                        
                        <!-- Stats Cards -->
                        <div class="row mt-3">
                            <div class="col-6">
                                <div class="card stat-card text-center">
                                    <div class="card-body">
                                        <h3 class="text-success" id="checkedInCount">0</h3>
                                        <small>Đã vào</small>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="card stat-card text-center">
                                    <div class="card-body">
                                        <h3 class="text-danger" id="checkedOutCount">0</h3>
                                        <small>Đã ra</small>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 mt-2">
                                <div class="card stat-card text-center">
                                    <div class="card-body">
                                        <h3 class="text-warning" id="lateCount">0</h3>
                                        <small>Đi muộn</small>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 mt-2">
                                <div class="card stat-card text-center">
                                    <div class="card-body">
                                        <h3 class="text-secondary" id="absentCount">0</h3>
                                        <small>Vắng</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ATTENDANCE LIST -->
                    <div class="col-md-8">
                        <div class="card shadow">
                            <div class="card-header bg-white">
                                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                    <h5 class="mb-0">
                                        <i class="bi bi-people"></i> Chấm công hôm nay
                                    </h5>
                                    <div class="d-flex gap-2 align-items-center">
                                        <!-- Date Navigation -->
                                        <button class="btn btn-sm btn-outline-secondary" onclick="previousDay()" title="Ngày trước">
                                            <i class="bi bi-chevron-left"></i>
                                        </button>
                                        
                                        <button class="btn btn-sm btn-primary" onclick="goToToday()" title="Hôm nay">
                                            <i class="bi bi-calendar-day"></i> Hôm nay
                                        </button>
                                        
                                        <button class="btn btn-sm btn-outline-secondary" onclick="nextDay()" title="Ngày sau">
                                            <i class="bi bi-chevron-right"></i>
                                        </button>
                                        
                                        <!-- Date Picker -->
                                        <input type="date" class="form-control form-control-sm" 
                                               id="dateFilter" 
                                               style="width: 160px;">
                                        
                                        <button class="btn btn-sm btn-primary" onclick="loadAttendance()">
                                            <i class="bi bi-arrow-clockwise"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Kỹ thuật viên</th>
                                                <th>Check-in</th>
                                                <th>Check-out</th>
                                                <th>Ca làm việc</th>
                                                <th>Giờ lịch</th>
                                                <th>Giờ thực tế</th>
                                                <th>Tăng ca</th>
                                                <th>Trạng thái</th>
                                                <th>Vị trí</th>
                                            </tr>
                                        </thead>
                                        <tbody id="attendanceTable">
                                            <tr>
                                                <td colspan="9" class="text-center py-4">
                                                    <div class="spinner-border text-primary" role="status">
                                                        <span class="visually-hidden">Loading...</span>
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Config & Scripts -->
    <script src="js/config.js"></script>
    <script src="js/notification-admin.js"></script>
    <script src="js/admin-attendance.js"></script>
    
    <script>
        // Logout function
        document.getElementById('logout-link').addEventListener('click', function(e) {
            e.preventDefault();
            if (confirm('Bạn có chắc muốn đăng xuất?')) {
                localStorage.removeItem('token');
                localStorage.removeItem('user');
                window.location.href = '/login';
            }
        });
        
        document.getElementById('dropdown-logout').addEventListener('click', function(e) {
            e.preventDefault();
            if (confirm('Bạn có chắc muốn đăng xuất?')) {
                localStorage.removeItem('token');
                localStorage.removeItem('user');
                window.location.href = '/login';
            }
        });
    </script>
</body>
</html>
