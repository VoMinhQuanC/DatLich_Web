<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kết quả thanh toán - VQTBike</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #fff7ed 0%, #f8fafc 100%);
        }

        .result-card {
            max-width: 720px;
            margin: 72px auto;
            border: 0;
            border-radius: 24px;
            box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
        }

        .result-icon {
            font-size: 72px;
            line-height: 1;
        }
    </style>
</head>
<body>
    <div class="container py-5">
        <div class="card result-card">
            <div class="card-body p-4 p-md-5 text-center">
                <div id="resultIcon" class="result-icon mb-3 text-success">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <span id="resultBadge" class="badge text-bg-success px-3 py-2 mb-3">Thanh toán thành công</span>
                <h1 id="resultTitle" class="h3 mb-3">Đơn đặt lịch đã được xác nhận</h1>
                <p id="resultMessage" class="text-muted mb-4">
                    Thanh toán VNPay đã hoàn tất. Bạn có thể kiểm tra lịch sử đặt lịch để xem trạng thái mới nhất.
                </p>

                <div class="bg-light rounded-4 p-3 p-md-4 text-start mb-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted">Cổng thanh toán</span>
                        <strong>VNPay</strong>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <span class="text-muted">Mã lịch hẹn</span>
                        <strong id="appointmentIdText">-</strong>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <span class="text-muted">Mã lỗi</span>
                        <strong id="errorCodeText">-</strong>
                    </div>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                    <a href="/booking-history" class="btn btn-primary btn-lg px-4">Xem lịch sử đặt lịch</a>
                    <a href="/booking" class="btn btn-outline-secondary btn-lg px-4">Đặt lịch mới</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        const PENDING_APPOINTMENT_ID_KEY = 'pendingAppointmentId';
        const PENDING_TOTAL_AMOUNT_KEY = 'pendingTotalAmount';
        const PENDING_BOOKING_FINGERPRINT_KEY = 'pendingBookingFingerprint';

        const params = new URLSearchParams(window.location.search);
        const status = params.get('status');
        const appointmentId = params.get('appointmentId');
        const error = params.get('error');

        localStorage.removeItem(PENDING_APPOINTMENT_ID_KEY);
        localStorage.removeItem(PENDING_TOTAL_AMOUNT_KEY);
        localStorage.removeItem(PENDING_BOOKING_FINGERPRINT_KEY);

        const resultBadge = document.getElementById('resultBadge');
        const resultIcon = document.getElementById('resultIcon');
        const resultTitle = document.getElementById('resultTitle');
        const resultMessage = document.getElementById('resultMessage');
        const appointmentIdText = document.getElementById('appointmentIdText');
        const errorCodeText = document.getElementById('errorCodeText');

        appointmentIdText.textContent = appointmentId || '-';
        errorCodeText.textContent = error || '-';

        if (status !== 'success') {
            resultBadge.className = 'badge text-bg-danger px-3 py-2 mb-3';
            resultBadge.textContent = 'Thanh toán thất bại';
            resultIcon.className = 'result-icon mb-3 text-danger';
            resultIcon.innerHTML = '<i class="bi bi-x-circle-fill"></i>';
            resultTitle.textContent = 'Thanh toán VNPay chưa hoàn tất';
            resultMessage.textContent = 'Đơn đặt lịch chưa được xác nhận. Bạn có thể quay lại bước đặt lịch để thử lại thanh toán.';
        }
    </script>
</body>
</html>
