<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập thành công - Sửa Xe Nhanh</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <!-- Thêm favicon từ CDN -->
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🔧</text></svg>">
    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background-color: #f8f9fa;
        }
        .success-container {
            text-align: center;
            padding: 2rem;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
            background-color: white;
            max-width: 500px;
            width: 90%;
        }
        .spinner-border {
            width: 3rem;
            height: 3rem;
            color: #0d6efd;
        }
        .logo-container {
            width: 80px;
            height: 80px;
            margin: 0 auto 1rem auto;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 50px;
            color: #0d6efd;
        }
        .avatar-container {
            width: 60px;
            height: 60px;
            margin: 0 auto 1rem auto;
            border-radius: 50%;
            background-color: #e9ecef;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 30px;
            color: #6c757d;
        }
        /* Thêm mới: Chỉ thị gỡ lỗi */
        .debug-info {
            margin-top: 20px;
            text-align: left;
            background-color: #f8f9fa;
            padding: 10px;
            border-radius: 5px;
            font-family: monospace;
            font-size: 12px;
            display: none;
        }
    </style>
</head>
<body>
    <div class="success-container">
        <!-- Sử dụng icon từ Bootstrap thay vì hình ảnh -->
        <div class="logo-container">
            <i class="bi bi-tools"></i>
        </div>
        
        <!-- Container cho avatar -->
        <div id="user-avatar" style="display: none;" class="avatar-container">
            <i class="bi bi-person"></i>
        </div>
        
        <div class="spinner-border mb-4" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        
        <h3 class="mb-3">Đăng nhập thành công!</h3>
        <p class="mb-2" id="welcome-message">Chào mừng bạn đã quay trở lại!</p>
        <p class="mb-4">Đang chuyển hướng đến trang chủ...</p>
        <div id="error-message" class="alert alert-danger" style="display: none;"></div>
        
        <!-- Thêm mới: Debug info -->
        <div id="debug-info" class="debug-info"></div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Lấy thông tin từ URL
            const urlParams = new URLSearchParams(window.location.search);
            const token = urlParams.get('token');
            const userParam = urlParams.get('user');
            const errorElement = document.getElementById('error-message');
            const userAvatar = document.getElementById('user-avatar');
            const welcomeMessage = document.getElementById('welcome-message');
            const debugInfo = document.getElementById('debug-info');
            
            // Hiển thị debug khi nhấn Shift + D
            document.addEventListener('keydown', function(e) {
                if (e.shiftKey && e.key === 'D') {
                    debugInfo.style.display = debugInfo.style.display === 'none' ? 'block' : 'none';
                }
            });

            // Luôn hiển thị icon người dùng
            userAvatar.style.display = 'flex';

            if (token && userParam) {
                try {
                    // Parse user JSON
                    const user = JSON.parse(decodeURIComponent(userParam));
                    
                    // Lưu thông tin đăng nhập vào localStorage
                    localStorage.setItem('token', token);
                    localStorage.setItem('user', JSON.stringify(user));
                    
                    // Cập nhật thông điệp chào mừng
                    if (user.fullName) {
                        welcomeMessage.textContent = `Chào mừng ${user.fullName} đã quay trở lại!`;
                    }
                    
                    // Debug
                    console.log('User info:', user);
                    
                    // Hiển thị thông tin người dùng để debug
                    debugInfo.innerHTML = `
                        <h5>Debug Info:</h5>
                        <p>User Data:</p>
                        <pre>${JSON.stringify(user, null, 2)}</pre>
                    `;
                    
                    // Kiểm tra các trường role khác nhau
                    const role = user.role || user.roleId || user.roleID || user.RoleID || user.Role;
                    console.log('Role detected:', role);
                    
                    // Chuyển hướng dựa trên vai trò người dùng
                    setTimeout(() => {
                        // Chuyển đổi role thành số nếu nó là chuỗi
                        const roleValue = parseInt(role) || role;
                        
                        if (roleValue === 1) {
                            // Admin
                            console.log('Redirecting to admin');
                            window.location.href = '/admin';
                        } else if (roleValue === 3) {
                            // Kỹ thuật viên
                            console.log('Redirecting to mechanic-dashboard');
                            window.location.href = '/mechanic-dashboard';
                        } else {
                            // Khách hàng thông thường
                            console.log('Redirecting to index for role:', roleValue);
                            window.location.href = '/';
                        }
                    }, 2000);
                } catch (error) {
                    console.error('Lỗi khi xử lý dữ liệu người dùng:', error);
                    errorElement.textContent = 'Đã xảy ra lỗi khi xử lý thông tin đăng nhập.';
                    errorElement.style.display = 'block';
                    
                    // Chuyển về trang đăng nhập sau 3 giây
                    setTimeout(() => {
                        window.location.href = '/login?error=invalid_user_data';
                    }, 3000);
                }
            } else {
                // Không có token hoặc thông tin người dùng
                errorElement.textContent = 'Thông tin đăng nhập không hợp lệ hoặc bị thiếu.';
                errorElement.style.display = 'block';
                
                // Chuyển về trang đăng nhập sau 3 giây
                setTimeout(() => {
                    window.location.href = '/login?error=missing_auth_data';
                }, 3000);
            }
        });
    </script>
</body>
</html>
